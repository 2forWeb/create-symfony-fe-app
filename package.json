{
    "name": "create-symfony-fe-app",
    "version": "1.0.0",
    "description": "A tool to create a fancy vite based symfony front-end application where you can maintain your stimulus and react controllers in TypeScript on its own folder",
    "keywords": [
        "controllers",
        "frontend",
        "react",
        "stimulus",
        "symfony",
        "typescript",
        "vite"
    ],
    "license": "ISC",
    "author": "Matias Jose",
    "bin": {
        "create-symfony-fe-app": "./dist/index.js"
    },
    "type": "commonjs",
    "main": "index.js",
    "scripts": {
        "typecheck": "tsc --noEmit",
        "build": "node ./node_modules/.bin/vite build",
        "build:watch": "node ./node_modules/.bin/vite build --watch",
        "lint": "oxlint 'src/**/*.{ts,tsx}'",
        "fmt": "oxfmt --check",
        "fmt:fix": "oxfmt",
        "test": "echo \"Error: no test specified\" && exit 1"
    },
    "devDependencies": {
        "@types/node": "^25.5.0",
        "oxfmt": "^0.42.0",
        "oxlint": "^1.57.0",
        "typescript": "^5.9.3",
        "vite": "^8.0.1"
    }
}
